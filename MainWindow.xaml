<Window x:Class="AiReviewerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Reviewer" Height="600" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e"
        Icon="pack://application:,,,/app.ico">

    <Window.Resources>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#6c7086"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="2,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- ИСПРАВЛЕНО: был жёлтый hover, теперь тёмно-фиолетовый -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2a2a3d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#cba6f7"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b4befe"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475a"/>
                                <Setter Property="Foreground" Value="#6c7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#45475a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#cdd6f4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#6c7086"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- ИСПРАВЛЕНО: тёмный стиль для ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#cba6f7"/>
                                <Setter Property="Foreground" Value="#1e1e2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Border Grid.Column="0" Background="#181825">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,20,20,24">
                    <TextBlock Text="AI Reviewer" Foreground="#cba6f7"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="v1.0 · Groq AI" Foreground="#45475a" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnFile" Style="{StaticResource NavButton}" Click="BtnFile_Click">
                        <TextBlock><Run Text="📄  "/><Run Text="Файл"/></TextBlock>
                    </Button>
                    <Button x:Name="BtnFolder" Style="{StaticResource NavButton}" Click="BtnFolder_Click">
                        <TextBlock><Run Text="📁  "/><Run Text="Папка"/></TextBlock>
                    </Button>
                    <Button x:Name="BtnHistory" Style="{StaticResource NavButton}" Click="BtnHistory_Click">
                        <TextBlock><Run Text="🕐  "/><Run Text="История"/></TextBlock>
                    </Button>
                </StackPanel>

                <Button DockPanel.Dock="Bottom" Style="{StaticResource NavButton}"
                        Click="BtnSettings_Click" Margin="0,0,0,16">
                    <TextBlock><Run Text="⚙  "/><Run Text="Настройки"/></TextBlock>
                </Button>

                <Grid/>
            </DockPanel>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Column="1" Margin="24">

            <!-- Панель: Файл -->
            <StackPanel x:Name="PanelFile" Visibility="Visible">
                <TextBlock Text="Проверить файл" Foreground="#cdd6f4"
                           FontSize="16" FontWeight="Medium" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFilePath" Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Tag="Путь к файлу..."
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Обзор..."
                            Style="{StaticResource SecondaryButton}"
                            Click="BrowseFile_Click" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Проверить ▶"
                            x:Name="BtnAnalyzeFile"
                            Style="{StaticResource PrimaryButton}"
                            Click="AnalyzeFile_Click"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="StatBugs" Text="—" Foreground="#f38ba8"
                                       FontSize="22" FontWeight="Medium" HorizontalAlignment="Center"/>
                            <TextBlock Text="Баги" Foreground="#6c7086"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="StatWarnings" Text="—" Foreground="#fab387"
                                       FontSize="22" FontWeight="Medium" HorizontalAlignment="Center"/>
                            <TextBlock Text="Предупреждения" Foreground="#6c7086"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="StatTips" Text="—" Foreground="#a6e3a1"
                                       FontSize="22" FontWeight="Medium" HorizontalAlignment="Center"/>
                            <TextBlock Text="Советы" Foreground="#6c7086"
                                       FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="#181825" CornerRadius="8" Padding="16">
                    <ScrollViewer Height="320" VerticalScrollBarVisibility="Auto">
                        <RichTextBox x:Name="OutputBox"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#cdd6f4"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="13" IsReadOnly="True" IsDocumentEnabled="True"/>
                    </ScrollViewer>
                </Border>

                <TextBlock x:Name="StatusText" Text="Готов к работе"
                           Foreground="#6c7086" FontSize="12" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Панель: Папка -->
            <StackPanel x:Name="PanelFolder" Visibility="Collapsed">
                <TextBlock Text="Проверить папку" Foreground="#cdd6f4"
                           FontSize="16" FontWeight="Medium" Margin="0,0,0,16"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFolderPath" Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Tag="Путь к папке..."
                             Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Обзор..."
                            Style="{StaticResource SecondaryButton}"
                            Click="BrowseFolder_Click" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Проверить ▶"
                            x:Name="BtnAnalyzeFolder"
                            Style="{StaticResource PrimaryButton}"
                            Click="AnalyzeFolder_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Язык:" Foreground="#6c7086"
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <!-- ИСПРАВЛЕНО: ComboBox с тёмным стилем -->
                    <ComboBox x:Name="LangCombo"
                              Background="#313244" Foreground="#45475a"
                              BorderBrush="#45475a" FontSize="13" Padding="8,4"
                              MinWidth="160">
                        <ComboBoxItem Content="C# (.cs)" Tag="cs" IsSelected="True"/>
                        <ComboBoxItem Content="JavaScript (.js)" Tag="js"/>
                        <ComboBoxItem Content="TypeScript (.ts)" Tag="ts"/>
                        <ComboBoxItem Content="Python (.py)" Tag="py"/>
                        <ComboBoxItem Content="Java (.java)" Tag="java"/>
                    </ComboBox>
                </StackPanel>

                <ProgressBar x:Name="FolderProgress" Height="4"
                             Background="#313244" Foreground="#cba6f7"
                             Margin="0,0,0,12" Visibility="Collapsed"/>

                <Border Background="#181825" CornerRadius="8" Padding="16">
                    <ScrollViewer Height="340" VerticalScrollBarVisibility="Auto">
                        <RichTextBox x:Name="FolderOutputBox"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#cdd6f4"
                                     FontFamily="Cascadia Code, Consolas, monospace"
                                     FontSize="13" IsReadOnly="True"/>
                    </ScrollViewer>
                </Border>

                <TextBlock x:Name="FolderStatusText" Text="Готов к работе"
                           Foreground="#6c7086" FontSize="12" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Панель: История -->
            <Grid x:Name="PanelHistory" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="История" Foreground="#cdd6f4"
                               FontSize="16" FontWeight="Medium" Margin="0,0,0,16"/>
                    <ListBox x:Name="HistoryList"
                             Background="#181825" BorderBrush="#313244"
                             Foreground="#cdd6f4" FontSize="12"
                             SelectionChanged="HistoryList_SelectionChanged"
                             Height="460"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Детали" Foreground="#cdd6f4"
                               FontSize="16" FontWeight="Medium" Margin="0,0,0,16"/>
                    <Border Background="#181825" CornerRadius="8" Padding="16">
                        <ScrollViewer Height="460" VerticalScrollBarVisibility="Auto">
                            <RichTextBox x:Name="HistoryDetailBox"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#cdd6f4"
                                         FontFamily="Cascadia Code, Consolas, monospace"
                                         FontSize="13" IsReadOnly="True"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Панель: Настройки -->
            <StackPanel x:Name="PanelSettings" Visibility="Collapsed">
                <TextBlock Text="Настройки" Foreground="#cdd6f4"
                           FontSize="16" FontWeight="Medium" Margin="0,0,0,24"/>
                <TextBlock Text="Groq API ключ" Foreground="#6c7086"
                           FontSize="12" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyBox"
                                 Background="#313244" Foreground="#cdd6f4"
                                 BorderBrush="#45475a" BorderThickness="1"
                                 Padding="10,8" FontSize="13" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="Сохранить"
                            Style="{StaticResource PrimaryButton}"
                            Click="SaveApiKey_Click"/>
                </Grid>
                <TextBlock Text="Текущий статус" Foreground="#6c7086"
                           FontSize="12" Margin="0,0,0,6"/>
                <TextBlock x:Name="ApiStatus" Foreground="#a6e3a1" FontSize="13"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>